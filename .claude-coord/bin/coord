#!/usr/bin/env python3
"""
Coordination CLI - Daemon Client Wrapper

Provides command-line interface to coordination daemon.
Compatible with claude-coord.sh command syntax.
"""

import sys
import os
import json
from pathlib import Path

# Add coord_service to path
sys.path.insert(0, str(Path(__file__).parent.parent))

from coord_service.client import CoordinationClient


def main():
    if len(sys.argv) < 2:
        print("Usage: coord <command> [args...]", file=sys.stderr)
        print("\nCommands:", file=sys.stderr)
        print("  register <agent-id> <pid>", file=sys.stderr)
        print("  unregister <agent-id>", file=sys.stderr)
        print("  cleanup-stale-agents [--dry-run]  # Manually cleanup dead agents", file=sys.stderr)
        print("  heartbeat <agent-id>", file=sys.stderr)
        print("  task-create <task-id> <subject> <description> [--depends-on <task1,task2,...>]", file=sys.stderr)
        print("              Note: Priority auto-derived from category (crit=0, high=1, med=2, low=3)", file=sys.stderr)
        print("  task-claim <agent-id> <task-id>", file=sys.stderr)
        print("  task-complete <agent-id> <task-id>", file=sys.stderr)
        print("  task-get <task-id>", file=sys.stderr)
        print("  task-list [--limit N]", file=sys.stderr)
        print("  task-search <prefix>", file=sys.stderr)
        print("  task-filter [--prefix PREFIX] [--status STATUS] [--limit N]", file=sys.stderr)
        print("  task-next <agent-id>", file=sys.stderr)
        print("  task-work <agent-id> <task-id>", file=sys.stderr)
        print("  task-done <agent-id> <task-id>", file=sys.stderr)
        print("  task-release <agent-id> <task-id>", file=sys.stderr)
        print("  task-add-dep <task-id> <depends-on>", file=sys.stderr)
        print("  task-remove-dep <task-id> <depends-on>", file=sys.stderr)
        print("  task-deps <task-id>", file=sys.stderr)
        print("  task-blocked", file=sys.stderr)
        print("  lock <agent-id> <file-path>", file=sys.stderr)
        print("  unlock <agent-id> <file-path>", file=sys.stderr)
        print("  lock-all <agent-id> <file1> <file2> ...", file=sys.stderr)
        print("  unlock-all <agent-id>", file=sys.stderr)
        print("  my-locks <agent-id>", file=sys.stderr)
        print("  status", file=sys.stderr)
        print("  velocity [--period '1 hour']", file=sys.stderr)
        print("  file-hotspots [--limit N]", file=sys.stderr)
        print("  task-timing <task-id>", file=sys.stderr)
        print("  repair-tasks [--dry-run]  # Fix corrupted tasks (completed_at but wrong status)", file=sys.stderr)
        print("  export [--output PATH]", file=sys.stderr)
        print("  import <json-path>", file=sys.stderr)
        sys.exit(1)

    command = sys.argv[1]
    args = sys.argv[2:]

    # Get project root (where .claude-coord is)
    project_root = os.getcwd()
    while project_root != '/':
        if os.path.exists(os.path.join(project_root, '.claude-coord')):
            break
        project_root = os.path.dirname(project_root)

    if not os.path.exists(os.path.join(project_root, '.claude-coord')):
        print("Error: Not in a coordination-enabled project", file=sys.stderr)
        sys.exit(1)

    # Auto-start daemon if not running
    def ensure_daemon_running():
        """Check if daemon is running, start it if not."""
        import hashlib
        import subprocess
        import time

        # Calculate socket path (same as server does)
        project_hash = hashlib.sha256(project_root.encode()).hexdigest()[:8]
        socket_path = f"/tmp/coord-{project_hash}.sock"

        # Check if socket exists and is accessible
        if os.path.exists(socket_path):
            try:
                # Try to connect
                test_client = CoordinationClient(project_root, timeout=1)
                test_client.call('status', {})
                return  # Daemon is running
            except:
                # Socket exists but daemon not responding, clean up
                try:
                    os.unlink(socket_path)
                except:
                    pass

        # Start daemon
        print("Starting coordination daemon...", file=sys.stderr)
        daemon_log = '/tmp/coord-daemon.log'
        coord_dir = os.path.join(project_root, '.claude-coord')

        # Start daemon process using python -m
        subprocess.Popen(
            [sys.executable, '-u', '-m', 'coord_service.daemon', 'start', '--project-root', project_root],
            stdout=open(daemon_log, 'a'),
            stderr=subprocess.STDOUT,
            cwd=coord_dir,
            start_new_session=True
        )

        # Wait for daemon to be ready (up to 5 seconds)
        for i in range(50):
            time.sleep(0.1)
            if os.path.exists(socket_path):
                try:
                    test_client = CoordinationClient(project_root, timeout=1)
                    test_client.call('status', {})
                    print("✓ Daemon started", file=sys.stderr)
                    return
                except:
                    pass

        print("Error: Failed to start daemon. Check /tmp/coord-daemon.log", file=sys.stderr)
        sys.exit(1)

    ensure_daemon_running()

    # Create client
    client = CoordinationClient(project_root, timeout=10)

    try:
        # Dispatch commands
        if command == 'register':
            agent_id, pid = args[0], int(args[1])
            result = client.call('register', {'agent_id': agent_id, 'pid': pid})
            print(f"✓ Registered {agent_id}")

        elif command == 'unregister':
            agent_id = args[0]
            result = client.call('unregister', {'agent_id': agent_id})
            print(f"✓ Unregistered {agent_id}")

        elif command == 'cleanup-stale-agents':
            dry_run = '--dry-run' in args
            result = client.call('cleanup_stale_agents', {'dry_run': dry_run})

            if result.get('cleaned'):
                for agent_id in result['cleaned']:
                    print(f"{'Would cleanup' if dry_run else 'Cleaned up'}: {agent_id}")
            else:
                print("No stale agents found")

        elif command == 'heartbeat':
            agent_id = args[0]
            result = client.call('heartbeat', {'agent_id': agent_id})
            print(f"✓ Heartbeat from {agent_id}")

        elif command == 'task-create':
            task_id, subject = args[0], args[1]
            description = args[2] if len(args) > 2 else ""
            depends_on = []
            priority = None
            spec_path = None

            # Parse optional flags
            if '--priority' in args:
                priority_idx = args.index('--priority')
                priority = int(args[priority_idx + 1])

            if '--depends-on' in args:
                depends_idx = args.index('--depends-on')
                depends_str = args[depends_idx + 1]
                depends_on = [dep.strip() for dep in depends_str.split(',')]

            if '--spec-path' in args:
                spec_idx = args.index('--spec-path')
                spec_path = args[spec_idx + 1]

            params = {
                'task_id': task_id,
                'subject': subject,
                'description': description
            }

            # Only include priority if explicitly provided
            if priority is not None:
                params['priority'] = priority

            if depends_on:
                params['depends_on'] = depends_on

            if spec_path:
                params['spec_path'] = spec_path

            result = client.call('task_create', params)

            if depends_on:
                print(f"✓ Created task {task_id} (depends on: {', '.join(depends_on)})")
            else:
                print(f"✓ Created task {task_id}")

        elif command == 'task-claim':
            agent_id, task_id = args[0], args[1]
            result = client.call('task_claim', {'agent_id': agent_id, 'task_id': task_id})
            print(f"✓ Claimed {task_id}")

        elif command == 'task-complete':
            agent_id, task_id = args[0], args[1]
            result = client.call('task_complete', {'agent_id': agent_id, 'task_id': task_id})
            print(f"✓ Completed {task_id}")

        elif command == 'task-get':
            task_id = args[0]
            result = client.call('task_get', {'task_id': task_id})
            task = result['task']

            # Print task details
            print(f"Task: {task['id']}")
            print(f"Subject: {task['subject']}")
            print(f"Description: {task['description']}")
            print(f"Status: {task['status']}")
            print(f"Priority: {task['priority']}")
            print(f"Owner: {task['owner'] or '(none)'}")

            if task.get('created_at'):
                print(f"Created: {task['created_at']}")
            if task.get('started_at'):
                print(f"Started: {task['started_at']}")
            if task.get('completed_at'):
                print(f"Completed: {task['completed_at']}")

            # Print dependencies
            if task.get('depends_on'):
                print(f"\nDepends on ({len(task['depends_on'])}):")
                for dep in task['depends_on']:
                    print(f"  - {dep}")
            else:
                print("\nDepends on: (none)")

            if task.get('blocks'):
                print(f"\nBlocks ({len(task['blocks'])}):")
                for blocker in task['blocks']:
                    print(f"  - {blocker}")
            else:
                print("\nBlocks: (none)")

        elif command == 'task-list':
            limit = 10
            show_all = False

            if '--limit' in args:
                limit_idx = args.index('--limit')
                limit = int(args[limit_idx + 1])

            if '--all' in args or '-a' in args:
                show_all = True

            result = client.call('task_list', {'limit': limit})

            if show_all:
                # Also show blocked tasks
                blocked_result = client.call('task_blocked', {})
                print("Available tasks:")

            for task in result['tasks']:
                print(f"  {task['id']}: {task['subject']} [{task['status']}]")

            if show_all and blocked_result['tasks']:
                print(f"\nBlocked tasks:")
                for task in blocked_result['tasks']:
                    blocked_count = task.get('blocked_by_count', 0)
                    print(f"  {task['id']}: {task['subject']} [blocked by {blocked_count}]")

        elif command == 'lock':
            agent_id, file_path = args[0], args[1]
            result = client.call('lock_acquire', {'agent_id': agent_id, 'file_path': file_path})
            print(f"✓ Locked {file_path}")

        elif command == 'unlock':
            agent_id, file_path = args[0], args[1]
            result = client.call('lock_release', {'agent_id': agent_id, 'file_path': file_path})
            print(f"✓ Unlocked {file_path}")

        elif command == 'my-locks':
            agent_id = args[0]
            result = client.call('lock_list', {'agent_id': agent_id})
            if result['locks']:
                print("My locks:")
                for lock in result['locks']:
                    print(f"  {lock['file_path']}")
            else:
                print("No locks held")

        elif command == 'status':
            result = client.call('status', {})
            print(f"Status: {result['status']}")
            print(f"Agents: {result['agents']}")
            print(f"Tasks:")
            print(f"  Pending: {result['tasks']['pending']}")
            print(f"  In Progress: {result['tasks']['in_progress']}")
            print(f"  Completed: {result['tasks']['completed']}")
            print(f"Locks: {result['locks']}")

            # Show corruption warnings if present
            if 'warnings' in result:
                warnings = result['warnings']
                print(f"\n⚠️  WARNINGS:")
                if 'corrupted_tasks' in warnings:
                    print(f"  Corrupted Tasks: {warnings['corrupted_tasks']}")
                    print(f"  {warnings['message']}")
                    if warnings.get('sample_ids'):
                        print(f"  Sample IDs: {', '.join(warnings['sample_ids'])}")
                    print(f"  Action: Run corruption cleanup or investigate cause")

        elif command == 'velocity':
            period = '1 hour'
            if '--period' in args:
                period_idx = args.index('--period')
                period = args[period_idx + 1]

            result = client.call('velocity', {'period': period})
            print(f"Velocity (last {period}):")
            print(f"  Completed: {result['completed_tasks']} tasks")
            print(f"  Throughput: {result['tasks_per_hour']} tasks/hour")
            print(f"  Avg Duration: {result['avg_duration_mins']} minutes")

        elif command == 'file-hotspots':
            limit = 10
            if '--limit' in args:
                limit_idx = args.index('--limit')
                limit = int(args[limit_idx + 1])

            result = client.call('file_hotspots', {'limit': limit})
            print("File Lock Hotspots:")
            for hotspot in result['hotspots']:
                print(f"  {hotspot['file_path']}: {hotspot['lock_count']} locks "
                      f"(avg {hotspot['avg_duration_mins']} min, {hotspot['contention_count']} contentions)")

        elif command == 'task-timing':
            task_id = args[0]
            result = client.call('task_timing', {'task_id': task_id})
            timing = result['timing']
            print(f"Task Timing: {task_id}")
            print(f"  Wait Time: {timing.get('wait_time_seconds', 0)}s")
            print(f"  Work Time: {timing.get('work_time_seconds', 0)}s")
            print(f"  Active Time: {timing.get('active_time_seconds', 0)}s")
            print(f"  Idle Time: {timing.get('idle_time_seconds', 0)}s")
            print(f"  Files Locked: {timing.get('files_locked', 0)}")
            print(f"  Files Modified: {timing.get('files_modified', 0)}")

            if result['files']:
                print("\n  Files:")
                for file in result['files']:
                    print(f"    {file['file_path']}: {file['lock_duration_secs']}s")

        elif command == 'repair-tasks':
            dry_run = '--dry-run' in args
            result = client.call('repair_tasks', {'dry_run': dry_run})

            if result.get('repaired'):
                print(f"\n{'Would repair' if dry_run else 'Repaired'} {len(result['repaired'])} corrupted tasks:")
                for task_id in result['repaired']:
                    print(f"  - {task_id}")
            else:
                print("✓ No corrupted tasks found")

        elif command == 'export':
            output_path = '.claude-coord/state.json'
            if '--output' in args:
                output_idx = args.index('--output')
                output_path = args[output_idx + 1]

            result = client.call('export_json', {'output_path': output_path})
            print(f"✓ Exported to {output_path}")

        elif command == 'import':
            json_path = args[0]
            result = client.call('import_json', {'json_path': json_path})
            print(f"✓ Imported from {json_path}")

        # Convenience commands for skills
        elif command == 'task-search':
            prefix = args[0]
            result = client.call('task_list', {'limit': 100})
            matching = [t for t in result['tasks'] if t['id'].startswith(prefix)]
            if matching:
                for task in matching:
                    print(f"{task['id']}: {task['subject']} [{task['status']}]")
            else:
                print(f"No tasks found with prefix: {prefix}", file=sys.stderr)
                sys.exit(1)

        elif command == 'task-filter':
            # Parse filter options
            prefix = None
            status = None
            limit = 1000

            i = 0
            while i < len(args):
                if args[i] == '--prefix' and i + 1 < len(args):
                    prefix = args[i + 1]
                    i += 2
                elif args[i] == '--status' and i + 1 < len(args):
                    status = args[i + 1]
                    i += 2
                elif args[i] == '--limit' and i + 1 < len(args):
                    limit = int(args[i + 1])
                    i += 2
                else:
                    i += 1

            # Build query
            query = "SELECT * FROM tasks WHERE 1=1"
            query_params = []

            if prefix:
                query += " AND id LIKE ?"
                query_params.append(f"{prefix}%")

            if status:
                query += " AND status = ?"
                query_params.append(status)

            query += " ORDER BY priority ASC, created_at ASC LIMIT ?"
            query_params.append(limit)

            # Execute direct query
            from coord_service.database import Database
            db = Database(str(Path(project_root) / '.claude-coord' / 'coordination.db'))
            tasks = db.query(query, tuple(query_params))

            if tasks:
                for task in tasks:
                    print(f"{task['id']}: {task['subject']} [{task['status']}]")
            else:
                filters = []
                if prefix:
                    filters.append(f"prefix={prefix}")
                if status:
                    filters.append(f"status={status}")
                filter_str = ", ".join(filters) if filters else "no filters"
                print(f"No tasks found ({filter_str})", file=sys.stderr)

        elif command == 'task-next':
            agent_id = args[0]
            result = client.call('task_list', {'limit': 1})
            if result['tasks']:
                task = result['tasks'][0]
                print(task['id'])
            else:
                print("(no tasks available)", file=sys.stderr)
                sys.exit(1)

        elif command == 'task-work':
            agent_id, task_id = args[0], args[1]
            # Claim task
            result = client.call('task_claim', {'agent_id': agent_id, 'task_id': task_id})
            print(f"✓ Claimed {task_id}")

            # Get task details
            task = client.call('task_get', {'task_id': task_id})
            print(json.dumps(task['task'], indent=2))

        elif command == 'task-done':
            agent_id, task_id = args[0], args[1]
            # Unlock all files first
            try:
                locks = client.call('lock_list', {'agent_id': agent_id})
                for lock in locks['locks']:
                    client.call('lock_release', {'agent_id': agent_id, 'file_path': lock['file_path']})
            except:
                pass

            # Complete task
            result = client.call('task_complete', {'agent_id': agent_id, 'task_id': task_id})
            print(f"✓ Completed {task_id}")

            # Show next available task
            result = client.call('task_list', {'limit': 1})
            if result['tasks']:
                task = result['tasks'][0]
                print(f"\nNext available: {task['id']}: {task['subject']}")

        elif command == 'task-release':
            agent_id, task_id = args[0], args[1]
            # Unlock all files
            try:
                locks = client.call('lock_list', {'agent_id': agent_id})
                for lock in locks['locks']:
                    client.call('lock_release', {'agent_id': agent_id, 'file_path': lock['file_path']})
            except:
                pass

            # Release task (set status back to pending)
            # Note: This requires a new daemon operation, for now just complete it
            print(f"✓ Released {task_id}")

        elif command == 'lock-all':
            agent_id = args[0]
            files = args[1:]
            for file_path in files:
                try:
                    client.call('lock_acquire', {'agent_id': agent_id, 'file_path': file_path})
                    print(f"✓ Locked {file_path}")
                except Exception as e:
                    print(f"✗ Failed to lock {file_path}: {e}", file=sys.stderr)

        elif command == 'unlock-all':
            agent_id = args[0]
            locks = client.call('lock_list', {'agent_id': agent_id})
            for lock in locks['locks']:
                client.call('lock_release', {'agent_id': agent_id, 'file_path': lock['file_path']})
                print(f"✓ Unlocked {lock['file_path']}")
            if not locks['locks']:
                print("No locks to release")

        elif command == 'task-add-dep':
            task_id, depends_on = args[0], args[1]
            result = client.call('task_add_dependency', {
                'task_id': task_id,
                'depends_on': depends_on
            })
            print(f"✓ Added dependency: {task_id} depends on {depends_on}")

        elif command == 'task-remove-dep':
            task_id, depends_on = args[0], args[1]
            result = client.call('task_remove_dependency', {
                'task_id': task_id,
                'depends_on': depends_on
            })
            print(f"✓ Removed dependency: {task_id} no longer depends on {depends_on}")

        elif command == 'task-deps':
            task_id = args[0]
            result = client.call('task_dependencies', {'task_id': task_id})

            print(f"Task: {task_id}")

            if result['depends_on']:
                print(f"\nDepends on ({len(result['depends_on'])}):")
                for dep in result['depends_on']:
                    print(f"  - {dep}")
            else:
                print("\nDepends on: (none)")

            if result['blocks']:
                print(f"\nBlocks ({len(result['blocks'])}):")
                for blocker in result['blocks']:
                    print(f"  - {blocker}")
            else:
                print("\nBlocks: (none)")

        elif command == 'task-blocked':
            result = client.call('task_blocked', {})

            if result['tasks']:
                print(f"Blocked tasks ({len(result['tasks'])}):")
                for task in result['tasks']:
                    blocked_count = task.get('blocked_by_count', 0)
                    print(f"  {task['id']}: {task['subject']} (blocked by {blocked_count} tasks)")
            else:
                print("No blocked tasks")

        else:
            print(f"Unknown command: {command}", file=sys.stderr)
            sys.exit(1)

    except RuntimeError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()
