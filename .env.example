# Temper AI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Providers ──────────────────────────────────────────
# Configure at least one provider. Uncomment and set values.

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# vLLM (local or remote)
# VLLM_BASE_URL=http://host.docker.internal:8000
# VLLM_MODEL=qwen3-next

# Ollama (local)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# Anthropic (requires: pip install temper-ai[anthropic])
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (requires: pip install temper-ai[gemini])
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# ── Database ───────────────────────────────���───────────────
# Default: PostgreSQL via docker compose (no change needed)
# TEMPER_DATABASE_URL=postgresql://temper_ai:temper_dev@postgres:5432/temper_ai

# ── Memory ─────────────────────────────────────────────────
# Default: in-memory (no persistence across restarts)
# TEMPER_MEMORY_BACKEND=in_memory

# ── Logging ──────────────────────────��─────────────────────
# TEMPER_LOG_LEVEL=INFO
