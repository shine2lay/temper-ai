# Meta-Autonomous Framework Configuration

# Database Configuration
DATABASE_URL=sqlite:///./meta_autonomous.db
# For production, use Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/meta_autonomous

# LLM Provider API Keys (optional, depending on which providers you use)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama Configuration (for local LLMs)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM Configuration (for local LLMs)
VLLM_BASE_URL=http://localhost:8000

# Observability Configuration
LOG_LEVEL=INFO
CONSOLE_VERBOSITY=standard  # minimal | standard | verbose
ENABLE_TRACING=true
TRACE_EVERYTHING=true

# Safety Configuration
DEFAULT_SAFETY_MODE=execute  # execute | dry_run | require_approval
ENABLE_APPROVAL_GATES=false

# Performance Configuration
MAX_CONCURRENT_WORKFLOWS=5
AGENT_TIMEOUT_SECONDS=300
TOOL_TIMEOUT_SECONDS=60

# Development Configuration
DEBUG=false
ENVIRONMENT=development  # development | staging | production
