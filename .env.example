# Temper AI Configuration

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Database
TEMPER_DATABASE_URL=postgresql://temper_ai:changeme@postgres:5432/temper_ai
# Fallback SQLite (development only)
# DATABASE_URL=sqlite:///./temper_ai.db

# LLM Provider
TEMPER_LLM_PROVIDER=vllm
TEMPER_LLM_MODEL=qwen3-next
TEMPER_LLM_BASE_URL=http://localhost:8000
# TEMPER_LLM_API_KEY=

# LLM Provider API Keys (optional, depending on which providers you use)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama Configuration (for local LLMs)
OLLAMA_BASE_URL=http://localhost:11434

# Application
TEMPER_LOG_LEVEL=INFO
TEMPER_WORKER_CONCURRENCY=4
CONSOLE_VERBOSITY=standard
ENABLE_TRACING=true

# Safety Configuration
DEFAULT_SAFETY_MODE=execute
ENABLE_APPROVAL_GATES=false

# Performance Configuration
MAX_CONCURRENT_WORKFLOWS=5
AGENT_TIMEOUT_SECONDS=300
TOOL_TIMEOUT_SECONDS=60

# Development Configuration
DEBUG=false
ENVIRONMENT=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-from-console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console
GOOGLE_OAUTH_CALLBACK_URL=https://yourdomain.com/auth/oauth/google/callback
GOOGLE_OAUTH_CALLBACK_URL_DEV=http://localhost:8000/auth/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile

# OAuth Token Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=generate-with-fernet-generate-key
