# Temper AI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Providers ──────────────────────────────────────────
# Configure at least one provider. Uncomment and set values.

# === Quickest start: OpenAI (most developers have this) ===
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# === Free / local: Ollama (no API key needed) ===
# Install: brew install ollama && ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# === Anthropic ===
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === vLLM (self-hosted) ===
# VLLM_BASE_URL=http://localhost:8000
# VLLM_MODEL=qwen3-next

# === Gemini ===
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# ── Database ──────────────────────────────────────────────
# Default: PostgreSQL via docker compose (no change needed)
# For local dev without Docker: use SQLite (auto-created)
# TEMPER_DATABASE_URL=sqlite:///data/dev.db
# TEMPER_DATABASE_URL=postgresql://temper_ai:temper_dev@localhost:5433/temper_ai

# ── Docker Paths ──────────────────────────────────────────
# Workspace directory mounted into the container
# WORKSPACE_DIR=./workspaces

# Claude Code CLI (optional — only needed for claude_code provider)
# CLAUDE_VERSIONS_DIR=/home/youruser/.local/share/claude/versions
# CLAUDE_CONFIG_HOST=/home/youruser/.claude

# ── Memory ────────────────────────────────────────────────
# Default: in-memory (no persistence across restarts)
# TEMPER_MEMORY_BACKEND=in_memory

# ── Logging ───────────────────────────────────────────────
# TEMPER_LOG_LEVEL=INFO
