# Temper AI Configuration

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Database (SQLite by default for local dev — no setup needed)
# TEMPER_DATABASE_URL=postgresql://temper_ai:changeme@postgres:5432/temper_ai

# LLM Provider (ollama is the easiest to start with — see https://ollama.com)
TEMPER_LLM_PROVIDER=ollama
TEMPER_LLM_MODEL=llama3.2
TEMPER_LLM_BASE_URL=http://localhost:11434
# TEMPER_LLM_API_KEY=

# Cloud LLM Providers (optional — uncomment and set the provider you use)
# TEMPER_LLM_PROVIDER=openai
# TEMPER_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=
#
# TEMPER_LLM_PROVIDER=anthropic
# TEMPER_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=
#
# TEMPER_LLM_PROVIDER=vllm
# TEMPER_LLM_MODEL=qwen3-next
# TEMPER_LLM_BASE_URL=http://localhost:8000

# Application
TEMPER_LOG_LEVEL=INFO
TEMPER_WORKER_CONCURRENCY=4
CONSOLE_VERBOSITY=standard
ENABLE_TRACING=true

# OpenTelemetry (required if ENABLE_TRACING=true)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=temper-ai

# CORS (required in server mode; comma-separated origins)
# TEMPER_CORS_ORIGINS=https://yourdomain.com

# API Key Security (recommended for production)
# TEMPER_API_KEY_PEPPER=generate-a-random-secret-here

# Dashboard Auto-Auth (optional — skips login page when set)
# Set to a valid API key so the dashboard authenticates automatically.
# TEMPER_DASHBOARD_TOKEN=tk_your_api_key_here

# Safety Configuration
DEFAULT_SAFETY_MODE=execute
ENABLE_APPROVAL_GATES=false

# Performance Configuration
MAX_CONCURRENT_WORKFLOWS=5
AGENT_TIMEOUT_SECONDS=300
TOOL_TIMEOUT_SECONDS=60

# Development Configuration
DEBUG=false
ENVIRONMENT=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-from-console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console
GOOGLE_OAUTH_CALLBACK_URL=https://yourdomain.com/auth/oauth/google/callback
GOOGLE_OAUTH_CALLBACK_URL_DEV=http://localhost:8000/auth/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile

# OAuth Token Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=generate-with-fernet-generate-key
