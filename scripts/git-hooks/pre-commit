#!/bin/bash
# Pre-commit hook — runs the same checks as .github/workflows/ci.yml so CI
# failures surface locally before push. Scope matches CI exactly:
#   - ruff check .                (whole project)
#   - mypy temper_ai/             (whole package)
#   - pytest tests/ -x --timeout=60   (full suite)
#
# Bypass with `git commit --no-verify` if you must.
#
# Install: ./scripts/install-git-hooks.sh
# or: git config core.hooksPath scripts/git-hooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PASS="\033[0;32m✓\033[0m"
FAIL="\033[0;31m✗\033[0m"

# ─── 0. Docs regeneration (existing behavior) ─────────────────────────────
RELEVANT_PATHS=(
    "temper_ai/tools/"
    "temper_ai/llm/providers/"
    "temper_ai/agent/"
    "temper_ai/safety/"
    "temper_ai/stage/topology.py"
    "scripts/generate_docs.py"
)

docs_needed=false
for path in "${RELEVANT_PATHS[@]}"; do
    if git diff --cached --name-only | grep -q "^${path}"; then
        docs_needed=true
        break
    fi
done

if [ "$docs_needed" = true ]; then
    echo "Source files changed — regenerating docs..."
    if ! PYTHONPATH="$REPO_ROOT" python3 "$REPO_ROOT/scripts/generate_docs.py" 2>&1; then
        echo -e "$FAIL Doc generation failed. Commit aborted."
        exit 1
    fi
    git add "$REPO_ROOT/docs/reference/"
    echo -e "$PASS Docs regenerated and staged."
fi

# ─── 1. ruff check . (whole project — matches CI) ─────────────────────────
echo "Running ruff check..."
if ! ruff check .; then
    echo ""
    echo -e "$FAIL ruff check failed."
    echo "   Try: ruff check --fix ."
    echo "   Or bypass: git commit --no-verify"
    exit 1
fi
echo -e "$PASS ruff check passed."

# ─── 2. mypy temper_ai/ (whole package — matches CI) ──────────────────────
echo "Running mypy on temper_ai/..."
if ! mypy temper_ai/ --ignore-missing-imports 2>&1; then
    echo ""
    echo -e "$FAIL mypy failed."
    echo "   Bypass: git commit --no-verify"
    exit 1
fi
echo -e "$PASS mypy passed."

# ─── 3. pytest (full suite — matches CI) ──────────────────────────────────
# CI runs `pytest tests/ -x --timeout=60` with a Postgres service container.
# Local dev may not have Postgres running, so tests/test_database/ is skipped
# by default. Set PRECOMMIT_RUN_DB=1 to include them (requires TEMPER_DATABASE_URL).
PYTEST_ARGS="tests/ -x --timeout=60 -q --no-header"
if [ -z "${PRECOMMIT_RUN_DB:-}" ]; then
    PYTEST_ARGS="$PYTEST_ARGS --ignore=tests/test_database"
fi

echo "Running pytest..."
# shellcheck disable=SC2086  (word splitting is intentional)
if ! pytest $PYTEST_ARGS 2>&1 | tail -20; then
    echo ""
    echo -e "$FAIL pytest failed."
    echo "   Bypass: git commit --no-verify"
    exit 1
fi
echo -e "$PASS pytest passed."

echo -e "$PASS All pre-commit checks passed."
